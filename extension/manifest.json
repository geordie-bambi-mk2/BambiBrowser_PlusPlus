{
  "manifest_version": 3,
  "name": "BambiBrowser+",
  "version": "6.3",
  "background": {
    "service_worker": "background.js"
  },
  "description": "Automatic fullscreen video hijack — configurable domains + blacklist",
  "permissions": ["storage", "tabs", "idle", "alarms"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "BambiBrowser+",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}